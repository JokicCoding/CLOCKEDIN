{
  "manifest_version": 3,
  "name": "Clocked In – Focus Blocker",
  "description": "Stay clocked in by blocking distracting or inappropriate sites and redirecting yourself to better, more productive pages.",
  "version": "1.0.4",
  "permissions": [
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["blocked.html", "blocked.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
